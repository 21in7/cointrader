BINANCE_API_KEY=
BINANCE_API_SECRET=
SYMBOLS=XRPUSDT
CORRELATION_SYMBOLS=BTCUSDT,ETHUSDT
LEVERAGE=20
DISCORD_WEBHOOK_URL=
ML_THRESHOLD=0.55
NO_ML_FILTER=true
MAX_SAME_DIRECTION=2
# Global defaults (fallback when no per-symbol override)
ATR_SL_MULT=2.0
ATR_TP_MULT=2.0
SIGNAL_THRESHOLD=3
ADX_THRESHOLD=25
VOL_MULTIPLIER=2.5

# Per-symbol strategy params (2026-03-21 운영 설정)
ATR_SL_MULT_XRPUSDT=1.5
ATR_TP_MULT_XRPUSDT=4.0
ADX_THRESHOLD_XRPUSDT=25
DASHBOARD_API_URL=http://10.1.10.24:8000
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# Sentiment fusion (게이트 A 스캐폴딩 — 봇 미연결, 백테스트 전용)
# 기본값 = 실측 확인된 로컬 MLX (OpenAI 호환). 미설정 시 아래 기본값 사용.
SENTIMENT_LLM_BASE_URL=http://localhost:8080/v1
SENTIMENT_LLM_MODEL=mlx-community/gemma-4-e4b-it-4bit
SENTIMENT_LLM_TIMEOUT=120
SENTIMENT_CACHE_DIR=data/sentiment_cache
# scripts/build_sentiment_dataset.py 과거 뉴스 수집용 (없으면 --dry-run만 가능)
ALPHAVANTAGE_API_KEY=
